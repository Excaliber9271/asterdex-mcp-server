# Aster DEX API Credentials
# Get your API key from https://asterdex.com/account/api-management
ASTER_API_KEY=your_api_key_here
ASTER_API_SECRET=your_api_secret_here

# Crypto Base Scanner API Key (optional — enables QFL base signals)
# Get your key from https://cryptobasescanner.com
CBS_API_KEY=your_cbs_key_here

# Hyperliquid uses public endpoints — no credentials needed
